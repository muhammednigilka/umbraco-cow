","value":"Jump into the Moo Family's world and enjoy tiny adventures full of fun and wonder. Short, sweet, and always a little magical!","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"shortsSourceMode","value":"[\"auto\"]","segment":null},{"culture":null,"editorAlias":"Umbraco.MultiNodeTreePicker","alias":"shortsSelectedShorts","value":"","segment":null},{"culture":null,"editorAlias":"Umbraco.Integer","alias":"shortsMaxItems","value":"4","segment":null},{"culture":null,"editorAlias":"Umbraco.Integer","alias":"shortsMobileAutoAdvanceMs","value":"2000","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"shortsCtaLabel","value":"View more Stories","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"shortsCtaUrl","value":"/stories","segment":null},{"culture":null,"editorAlias":"Umbraco.MediaPicker3","alias":"shortsCtaImage","value":"","segment":null}]},{"contentTypeKey":"f3a00015-0000-0000-0000-000000000015","key":"aa000106-0000-0000-0000-000000000106","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"poweredBySectionId","value":"marketplace","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"poweredByHeading","value":"Powered by the Best in Gaming","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"poweredBySubheading","value":"Teaming up with industry leaders to build the ultimate gaming universe.","segment":null},{"culture":null,"editorAlias":"Umbraco.BlockList","alias":"poweredByLogos","value":"{\"contentData\":[{\"contentTypeKey\":\"e1a00007-0000-0000-0000-000000000007\",\"key\":\"bb000001-0000-0000-0000-000000000001\",\"values\":[{\"culture\":null,\"editorAlias\":\"Umbraco.TextBox\",\"alias\":\"logoName\",\"value\":\"Steam\",\"segment\":null},{\"culture\":null,\"editorAlias\":\"Umbraco.MediaPicker3\",\"alias\":\"logoImage\",\"value\":\"\",\"segment\":null},{\"culture\":null,\"editorAlias\":\"Umbraco.TextBox\",\"alias\":\"logo