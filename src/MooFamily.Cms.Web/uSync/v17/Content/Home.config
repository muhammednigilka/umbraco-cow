":"altText","value":"The Moo Family characters together","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"caption","value":"","segment":null}]},{"contentTypeKey":"e1a00009-0000-0000-0000-000000000009","key":"aa000010-0000-0000-0000-000000000010","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"bulletListTitle","value":"","segment":null},{"culture":null,"editorAlias":"Umbraco.MultipleTextstring","alias":"bulletItems","value":"Empower Creativity\nFoster Growth\nBuild Community","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"aa000011-0000-0000-0000-000000000011","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Explore Trending Games","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"aa000012-0000-0000-0000-000000000012","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"<p>Teaming up with industry leaders to build the ultimate gaming universe.</p>","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"aa000013-0000-0000-0000-000000000013","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Featured Characters","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"aa000014-0000-0000-0000-000000000014","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"<p>Meet the Moo Family -- six friendly characters who lead every story. Each brings a unique perspective on curiosity, kindness, and play.</p>","segment":null}]},{"contentTypeKey":"a5e996c2-c7e5-4e1e-a69a-12332079a5e4","key":"aa000015-0000-0000-0000-000000000015","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"label","value":"Browse Characters","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"url","value":"/moo-family","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"style","value":"[\"primary\"]","segment":null},{"culture":null,"editorAlias":"Umbraco.TrueFalse","alias":"openInNewTab","value":"0","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"aa000016-0000-0000-0000-000000000016","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Where Adventure Comes to Life","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"aa000017-0000-0000-0000-000000000017","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"<p>In Cow Paradise, stories unfold across tropical islands, hidden treasures, and vibrant digital realms. It's a world filled with charm, creativity, and opportunity -- where players discover lovable characters, complete exciting challenges, and collect unique items that shape their identity. More than just a game, Cow Paradise is a universe built to grow with its community.</p>","segment":null}]},{"contentTypeKey":"e1a0000a-0000-0000-0000-00000000000a","key":"aa000018-0000-0000-0000-000000000018","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"videoUrl","value":"","segment":null},{"culture":null,"editorAlias":"Umbraco.MediaPicker3","alias":"videoPosterImage","value":"","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"videoCaption","value":"Adventures","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"aa000019-0000-0000-0000-000000000019","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Game Shorts","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"aa000020-0000-0000-0000-000000000020","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"<p>Jump into the Moo Family's world and enjoy tiny adventures full of fun and wonder. Short, sweet, and always a little magical!</p>","segment":null}]},{"contentTypeKey":"a5e996c2-c7e5-4e1e-a69a-12332079a5e4","key":"aa000021-0000-0000-0000-000000000021","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"label","value":"View more Stories","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"url","value":"/stories","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"style","value":"[\"primary\"]","segment":null},{"culture":null,"editorAlias":"Umbraco.TrueFalse","alias":"openInNewTab","value":"0","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"aa000022-0000-0000-0000-000000000022","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"<p>Teaming up with industry leaders to build the ultimate gaming universe.</p>","segment":null}]},{"contentTypeKey":"e1a00008-0000-0000-0000-000000000008","key":"aa000023-0000-0000-0000-000000000023","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"logoStripTitle","value":"Powered by the Best in Gaming","segment":null},{"culture":null,"editorAlias":"Umbraco.BlockList","alias":"logoStripItems","value":"{\"contentData\":[{\"contentTypeKey\":\"e1a00007-0000-0000-0000-000000000007\",\"key\":\"bb000001-0000-0000-0000-000000000001\",\"values\":[{\"culture\":null,\"editorAlias\":\"Umbraco.TextBox\",\"alias\":\"logoName\",\"value\":\"Steam\",\"segment\":null},{\"culture\":null,\"editorAlias\":\"Umbraco.MediaPicker3\",\"alias\":\"logoImage\",\"value\":\"\",\"segment\":null},{\"culture\":null,\"editorAli