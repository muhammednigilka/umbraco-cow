  <Properties>
    <title>
      <Value><![CDATA[Meet the Moo Family]]></Value>
    </title>
    <metaDescription>
      <Value><![CDATA[Friendly characters who make learning fun through stories, games, songs, and adventures. Join Little Jack and his friends as they explore letters, numbers, emotions, and life lessons together.]]></Value>
    </metaDescription>
    <blocks>
      <Value><![CDATA[{"contentData":[{"contentTypeKey":"e1a00001-0000-0000-0000-000000000001","key":"6308ed6c-ffd6-0449-8ab9-24eb7ad37d7e","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"bannerTitle","value":"Meet the Moo Family","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"bannerSubtitle","value":"Friendly cows. Big adventures.","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"bannerBody","value":"Six characters -- each with a unique personality -- guide the games, stories, and lessons that make Cow Paradise feel like home.","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"ctaPrimaryLabel","value":"Browse Characters","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"ctaPrimaryUrl","value":"#characters","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"ctaSecondaryLabel","value":"Explore Stories","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"ctaSecondaryUrl","value":"/stories","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"879482ae-a25a-db4a-b866-20437b84721e","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"A family for every kind of day","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"5cb536b0-531c-1744-86b9-c4c0a05d5ad6","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eWhether you\u0027re feeling curious like Little Jack, brave like Lulu, or playful like Milo, there\u0027s a Moo Family character ready to join the adventure. Learn letters, numbers, emotions, and life lessons alongside friends who care.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"b37382a4-7c79-be40-bdcf-e0b4fc6ad5d2","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Meet each character","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"c449ea87-eee2-7d4e-bf23-db3f231edca7","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eEach character has their own story, accent color, and signature moments across our games and stories. Browse the characters section above to learn what makes each one special.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"fb08521a-4cad-d442-9736-eec84a770298","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Learning Categories","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"9684f9ae-9180-f64c-a16f-9262136ac75e","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eSix themed playlists turn every screen-time moment into a learning moment.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"e1a00003-0000-0000-0000-000000000003","key":"a1b3b838-c8c9-5b48-8b4c-9a1557c1a51f","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureNumber","value":"01","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureTitle","value":"Alphabet adventures","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"featureDescription","value":"Trace, sing, and play your way through the alphabet alongside the Moo Family.","segment":null}]},{"contentTypeKey":"e1a00003-0000-0000-0000-000000000003","key":"257d5b0e-4c34-d041-a7b0-cf770a3a079c","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureNumber","value":"02","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureTitle","value":"ABC Puzzles","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"featureDescription","value":"Match letters with friendly characters and build early-reading confidence one puzzle at a time.","segment":null}]},{"contentTypeKey":"e1a00003-0000-0000-0000-000000000003","key":"78e2f9a6-23d0-404e-a377-f87d7b7c9fd8","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureNumber","value":"03","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureTitle","value":"Letters seek \u0026 find","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"featureDescription","value":"Hunt for hidden letters inside cheerful scenes -- a playful eye-and-mind workout.","segment":null}]},{"contentTypeKey":"e1a00003-0000-0000-0000-000000000003","key":"2f7046f6-f6fb-e54b-b906-2e746503927e","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureNumber","value":"04","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureTitle","value":"Candy words","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"featureDescription","value":"Sweet, simple word games that grow with your child\u0027s vocabulary.","segment":null}]},{"contentTypeKey":"e1a00003-0000-0000-0000-000000000003","key":"6957c67b-5a8f-a445-ba0d-efda004e1cda","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureNumber","value":"05","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureTitle","value":"Bedtime Smiles","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"featureDescription","value":"Calming stories and gentle activities to wind down at the end of the day.","segment":null}]},{"contentTypeKey":"e1a00003-0000-0000-0000-000000000003","key":"6e8a778d-a53a-7e4c-b1d4-cecb5e97b2f3","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureNumber","value":"06","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureTitle","value":"Brain Games","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"featureDescription","value":"Logic puzzles, pattern play, and memory challenges that grow with the child.","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"9851f95a-34e7-784c-bfc7-dc017bb2a430","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Watch the shorts","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"4fb087fb-a4c2-8445-b87b-8aef00193d3a","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eShort animated clips starring the Moo Family -- about kindness, curiosity, and finding fun in everyday moments. New episodes added regularly to Cow Paradise Shorts.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"a5e996c2-c7e5-4e1e-a69a-12332079a5e4","key":"f09bfb19-7e74-d441-96e1-7fbc8afe05bd","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"label","value":"Browse all shorts","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"url","value":"/stories","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"style","value":"[\"primary\"]","segment":null},{"culture":null,"editorAlias":"Umbraco.TrueFalse","alias":"openInNewTab","value":"0","segment":null}]}],"settingsData":[],"layout":{"Umbraco.BlockList":[{"contentKey":"6308ed6c-ffd6-0449-8ab9-24eb7ad37d7e"},{"contentKey":"879482ae-a25a-db4a-b866-20437b84721e"},{"contentKey":"5cb536b0-531c-1744-86b9-c4c0a05d5ad6"},{"contentKey":"b37382a4-7c79-be40-bdcf-e0b4fc6ad5d2"},{"contentKey":"c449ea87-eee2-7d4e-bf23-db3f231edca7"},{"contentKey":"fb0