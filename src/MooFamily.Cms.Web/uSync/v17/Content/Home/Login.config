    </title>
    <metaDescription>
      <Value><![CDATA[Sign in to continue your adventure with the Moo Family. Save your progress, earn rewards, and join the Cowverse community.]]></Value>
    </metaDescription>
    <blocks>
      <Value><![CDATA[{"contentData":[{"contentTypeKey":"e1a00001-0000-0000-0000-000000000001","key":"c61e63f6-48c1-844b-8243-82e19f8c029d","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"bannerTitle","value":"Welcome Back to Cow Paradise","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"bannerSubtitle","value":"Where Adventure Comes To Life","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"bannerBody","value":"Sign in to continue your adventure with the Moo Family. Save progress, earn rewards, and join the Cowverse community.","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"ctaPrimaryLabel","value":"Create Account","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"ctaPrimaryUrl","value":"/login?mode=signup","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"ctaSecondaryLabel","value":"Forgot password","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"ctaSecondaryUrl","value":"/login?mode=reset","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"6ab9407c-8b3b-d542-a72c-b3c611b924bd","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Why join the Cowverse?","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"e1a00003-0000-0000-0000-000000000003","key":"6e300f2a-8902-6041-863a-3ba5507377eb","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureNumber","value":"01","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureTitle","value":"Save your progress","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"featureDescription","value":"Pick up where you left off across every game, on every device.","segment":null}]},{"contentTypeKey":"e1a00003-0000-0000-0000-000000000003","key":"a3e139b3-72b6-364a-a0d5-89dc428dbbf6","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureNumber","value":"02","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureTitle","value":"Earn rewards","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"featureDescription","value":"Daily quests, achievements, and chests waiting just for you.","segment":null}]},{"contentTypeKey":"e1a00003-0000-0000-0000-000000000003","key":"c7549e52-eb33-ac4c-a803-9d642fce95b9","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureNumber","value":"03","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureTitle","value":"Join the community","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"featureDescription","value":"Friend lists, leaderboards, and parent-friendly multiplayer rooms.","segment":null}]},{"contentTypeKey":"e1a00003-0000-0000-0000-000000000003","key":"1d3f246c-6f5a-7a4d-9e17-e0df8afdaacb","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureNumber","value":"04","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureTitle","value":"Get early access","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"featureDescription","value":"Sign-in members get first access to new games, stories, and shorts.","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"2d289d76-fef7-2847-abe2-c84e710853f3","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Before you continue","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h3\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"133b0a38-183c-7543-b690-40473bb11eac","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eBy signing in you agree to our \u003ca href=\"/terms\"\u003eTerms of Service\u003c/a\u003e and \u003ca href=\"/privacy-policy\"\u003ePrivacy Policy\u003c/a\u003e. We protect your information and never sell your data.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"f3a1dbee-5f10-5e4c-87fb-e43e73710444","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"New to Cow Paradise?","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h3\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"a922f08a-876a-084a-899f-f1afdb119d9f","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eCreating an account takes about a minute. You\u0027ll be asked for an email, a display name, and a password. Got a referral code from a friend? Drop it in during signup so both of you earn bonus rewards.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"a5e996c2-c7e5-4e1e-a69a-12332079a5e4","key":"6529fda3-ca66-6f4f-bd3b-df5f0aa082fa","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"label","value":"Create an Account","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"url","value":"/login?mode=signup","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"style","value":"[\"primary\"]","segment":null},{"culture":null,"editorAlias":"Umbraco.TrueFalse","alias":"openInNewTab","value":"0","segment":null}]}],"settingsData":[],"layout":{"Umbraco.BlockList":[{"contentKey":"c61e63f6-48c1-844b-8243-82e19f8c029d"},{"contentKey":"6ab9407c-8b3b-d542-a72c-b3c611b924bd"},{"contentKey":"6e300f2a-8902-6041-863a-3ba5507377eb"},{"contentKey":"a3e139b3-72b6-364a-a0d5-89dc428dbbf6"},{"contentKey":"c7549e52-eb33-ac4c-a803-9d642fce95b9"},{"contentKey":"1d3f246c-6f5a-7a4d-9e17-e0df8afdaacb"},{"contentKey":"2d289d76-fef7-2847-abe2-c84e710853f3"},{"contentKey":"133