  <Info>
    <Name>Trending Games Section</Name>
    <Icon>icon-trophy</Icon>
    <Thumbnail>folder.png</Thumbnail>
    <Description><![CDATA[Trending games carousel plus the Featured Characters callout. Matches the React TrendingGamesSection component.]]></Description>
    <AllowAtRoot>False</AllowAtRoot>
    <ListView>00000000-0000-0000-0000-000000000000</ListView>
    <Variations>Nothing</Variations>
    <IsElement>true</IsElement>
    <HistoryCleanup>
