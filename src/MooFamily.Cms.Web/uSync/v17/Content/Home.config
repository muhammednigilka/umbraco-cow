    <title>
      <Value><![CDATA[Welcome to Cow Paradise]]></Value>
    </title>
    <metaDescription>
      <Value><![CDATA[Where Games Become a Universe. Cow Paradise creates more than just games — we're building a playful universe filled with stories, adventures, and unforgettable characters.]]></Value>
    </metaDescription>
    <heroImage>
      <Value><![CDATA[]]></Value>
    </heroImage>
    <blocks>
      <Value><![CDATA[{"contentData":[{"contentTypeKey":"e1a00001-0000-0000-0000-000000000001","key":"7705a7cd-fce3-9d47-8427-22d796f016f0","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"bannerTitle","value":"Where Games Become a Universe","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"bannerSubtitle","value":"Welcome to Cow Paradise","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"bannerBody","value":"We\u0027re building a playful universe filled with stories, adventures, and unforgettable characters. Play, learn, and grow with the Moo Family.","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"ctaPrimaryLabel","value":"Explore Games","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"ctaPrimaryUrl","value":"/games","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"ctaSecondaryLabel","value":"Meet the Moo Family","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"ctaSecondaryUrl","value":"/moo-family","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"fa6f11fd-59ec-a546-888b-028e08943ec9","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Trending Games","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"29ee4227-3970-c34e-a637-06af10f74446","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eFrom racing to puzzles, our growing collection of games invites players of every age to discover Cow Paradise. Featured titles update regularly -- check back often for new adventures.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"36f0379f-031b-e74e-bbd3-fded5f9c01e4","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Meet the Moo Family","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"4791016a-d81a-bb4e-b461-ba59bda98624","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eSix friendly characters lead every story -- Ellie, Little Jack, Lulu, Milo, Moo, and Tina. Each brings a unique perspective on curiosity, kindness, and play.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"e1a00002-0000-0000-0000-000000000002","key":"a346ac32-3e46-fc4c-a331-abc54362224f","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"statValue","value":"200K+","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"statLabel","value":"Total Downloads","segment":null}]},{"contentTypeKey":"e1a00002-0000-0000-0000-000000000002","key":"02d56602-18d8-1448-8f63-73ac4e40d266","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"statValue","value":"98%","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"statLabel","value":"Parents Satisfaction","segment":null}]},{"contentTypeKey":"e1a00002-0000-0000-0000-000000000002","key":"45196dc8-2a01-254f-ba68-7876c737cf51","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"statValue","value":"5+","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"statLabel","value":"Years of Experience","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"ec629e1f-392b-344c-869d-cf0e90e87e29","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Powered by the Best in Gaming","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"e709cba5-e833-a340-84ff-e270369607cb","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eCow Paradise is built on industry-leading tools and platforms. We partner with the best in gaming engines, distribution, analytics, and creative tools so families get a polished experience on every device.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"7140bc65-bf8d-1c42-ab74-939594d0cc78","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Subscribe for new stories","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"e1a00006-0000-0000-0000-000000000006","key":"a68833f0-2ec1-844e-950b-5fa977cf1826","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"newsletterTitle","value":"Stay in the loop","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"newsletterDescription","value":"Get a short email when we ship a new game, character, or story. No spam -- ever.","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"newsletterCtaLabel","value":"Subscribe for New Stories","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"newsletterPlaceholder","value":"Enter your email","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"a245e31c-257f-bd4a-b0b6-0b44a90e7db9","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Join the Cowverse","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"a5e996c2-c7e5-4e1e-a69a-12332079a5e4","key":"fd7318d3-dfef-8a43-aa3b-650cb6cd7ceb","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"label","value":"Join Our Community","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox",