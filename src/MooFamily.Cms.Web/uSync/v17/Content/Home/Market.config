  <Properties>
    <title>
      <Value><![CDATA[The Cow Paradise Market]]></Value>
    </title>
    <metaDescription>
      <Value><![CDATA[Power up your adventure with premium items, chests, shop items, battle passes, and exclusive privileges across the Cowverse.]]></Value>
    </metaDescription>
    <blocks>
      <Value><![CDATA[{"contentData":[{"contentTypeKey":"e1a00001-0000-0000-0000-000000000001","key":"be5cc872-df58-7b4a-8418-551dbabb7b44","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"bannerTitle","value":"The Cow Paradise Market","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"bannerSubtitle","value":"Power up your adventure","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"bannerBody","value":"Discover items, chests, and passes that make your Cow Paradise journey richer. Items rotate weekly -- check back often for new drops.","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"ctaPrimaryLabel","value":"Browse Items","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"ctaPrimaryUrl","value":"#shop-items","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"ctaSecondaryLabel","value":"Battle Pass","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"ctaSecondaryUrl","value":"#battle-pass","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"2cb00a4e-3391-3d47-bd55-5288e8128fa5","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Premium Items","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"1edef406-9430-fd48-bb12-9cbb8374b748","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003ePremium Items unlock cosmetics, gameplay boosts, and exclusive characters. Pick what fits your play-style -- each item shows its cost, daily limit, and whether it requires an active Battle Pass.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"b5f9ff83-609b-9d4d-b11f-aad95677ed63","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Shop Items","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"211ce5cf-6d8b-f64b-bee2-247ed173cdb9","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eBrowse the daily Shop for currency packs, time-limited gear, and seasonal collectibles. Prices and stock refresh every 24 hours.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"0d216792-279d-7542-b62a-0129a4b8a3b6","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Battle Pass","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"349e3340-a13c-d144-92b7-c28cc9b5fe4b","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eThe Cow Paradise Battle Pass is your season-long upgrade. Unlock \u003cstrong\u003ePremium Store Access\u003c/strong\u003e, \u003cstrong\u003ePremium Badge\u003c/strong\u003e, \u003cstrong\u003ePremium Reward\u003c/strong\u003e tiers, and \u003cstrong\u003ePremium Achievements\u003c/strong\u003e as you play. Progress carries over your account across all our games.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"6a00e444-e673-194f-a058-91c16f0f5e5e","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Chests","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"9b37027c-074c-9448-be23-621ab03c756e","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eOpen Chests to win random rewards from one of three tiers. Higher-tier chests roll richer drop tables.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"e1a00003-0000-0000-0000-000000000003","key":"bd81965d-88f1-5548-b548-cb93edfa14fa","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureNumber","value":"01","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureTitle","value":"Common Reward","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"featureDescription","value":"Small currency bundles, basic boosts, and starter cosmetics. Reliable, friendly, and fun.","segment":null}]},{"contentTypeKey":"e1a00003-0000-0000-0000-000000000003","key":"33f4f4a0-5b16-9f44-bf7d-ced7c8303bba","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureNumber","value":"02","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureTitle","value":"Rare Reward","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"featureDescription","value":"Mid-tier cosmetics, character skins, and Forge Time Reduction tokens. Limited but reachable with regular play.","segment":null}]},{"contentTypeKey":"e1a00003-0000-0000-0000-000000000003","key":"97f1321d-8a29-d346-b02c-d04c1d5f184d","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureNumber","value":"03","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureTitle","value":"Premium Reward","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"featureDescription","value":"Top-tier items: exclusive characters, animated skins, and Win Reward multipliers. Rare drops worth chasing.","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"52e8a12c-55ac-0f4b-96bc-fa9151e105b9","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Privileges","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"ab157e54-c2ca-984c-bf1a-9bd42969fad3","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003ePrivileges grant special access in the Cowverse:\u003c/p\u003e","segment":null}]},{"contentTypeKey":"e1a00003-0000-0000-0000-000000000003","key":"2304006b-332d-1548-a4c9-8f495dcb425a","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureNumber","value":"01","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureTitle","value":"Tournament Entry","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"featureDescription","value":"Enter monthly tournaments to play against the top players in Cow Paradise and win exclusive rewards.","segment":null}]},{"contentTypeKey":"e1a00003-0000-0000-0000-000000000003","key":"fca68529-4510-8d4c-b89a-fbd43513169b","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureNumber","value":"02","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureTitle","value":"Private Room Entry","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"featureDescription","value":"Create a private multiplayer room for friends and family -- safe, ad-free, and just for you.","segment":null}]},{"contentTypeKey":"e1a00003-0000-0000-0000-000000000003","key":"7eecceb3-3c1c-2e43-9ff9-a354f99b9bc8","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureNumber","value":"03","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureTitle","value":"NFT Purchase","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"featureDescription","value":"Pick up limited collectible items from special drops. NFT items are optional and never required to play.","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"509f2de3-be1e-3347-a975-7a518ca50d2d","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Frequently asked","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"8fa734e0-2af8-4d45-bea9-ed3bcbe4c003","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003e\u003cstrong\u003eAre purchases refundable?\u003c/strong\u003e\u003cbr\u003eVirtual goods are non-refundable except where required by law. See our \u003ca href=\"/terms\"\u003eTerms of Service\u003c/a\u003e for the full policy.\u003cbr\u003e\u003cbr\u003e\u003cstrong\u003eCan my child make purchases?\u003c/strong\u003e\u003cbr\u003ePurchases require an account-level confirmation. Parents and guardians can disable in-game purchases entirely in profile settings.\u003cbr\u003e\u003cbr\u003e\u003cstrong\u003eDo items expire?\u003c/strong\u003e\u003cbr\u003eSeasonal items expire at the end of their season. Permanent items stay in your inventory forever.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"a5e996c2-c7e5-4e1e-a69a-12332079a5e4","key":"50f5385f-a632-e14d-a7f7-f4ec3e10e5be","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"label","value":"Read the full terms","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"url","value":"/terms","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"style","value":"[\"secondary\"]","segment":null},{"culture":null,"editorAlias":"Umbraco.TrueFalse","alias":"openInNewTab","value":"0","segment":null}]}],"settingsData":[],"layout":{"Umbraco.BlockList":[{"contentKey":"be5cc872-df58-7b4a-8418-551dbabb7b44"},{"contentKey":"2cb00a4e-3391-3d47-bd55-5288e8128fa5"},{"contentKey":"1edef406-9430-fd48-bb12-9cbb8374b748"},{"contentKey":"b5f9ff83-609b-9d4d-b11f-aad95677ed63"},{"contentKey":"211ce5cf-6d8b-f64b-bee2-247ed173cdb9"},{"contentKey":"0d216792-279d-7542-b62a-0129a4b8a3b6"},{"contentKey":"349e3340-a13c-d144-92b7-c28cc9b5fe4b"},{"contentKey":"6a00e444-e673-194f-a058-91c16f0f5e5e"},{"contentKey":"9b37027c-074c-9448-be23-621ab03c756e"},{"contentKey":"bd81965d-88f1-5548-b548-cb93edfa14fa"},{"contentKey":"33f4f4a0-5b16-9f44-bf7d-ced7c8303bba"},{"contentKey":"97f1321d-8a29-d346-b02c-d04c1d5f184d"},{"contentKey":"52e8a12c-55ac-0f4b-96bc-fa9151e105b9"},{"contentKey":"ab157e54-c2ca-984c-bf1a-9bd42969fad3"},{"contentKey":"2304006b-332d-1548-a4c9-8f495dcb425a"},{"contentKey":"fca68529-4510-8d4c-b89a-fbd43513169b"},{"contentKey":"7eecceb3-3c1c-2e43-9ff9-a354f99b9bc8"},{"contentKey":"509f2de3-be1e-3347-a975-7a518ca50d2d"},{"contentKey":"8fa734e0-2af8-4d45-bea9-ed3bcbe4c003"},{"contentKey":"50f5385f-a632-e14d-a7f7-f4ec3e10e5be"}]},"expose":[{"culture":null,"contentKey":"be5cc872-df58-7b4a-8418-551dbabb7b44","segment":null},{"culture":null,"contentKey":"2cb00a4e-3391-3d47-bd55-5288e8128fa5","segment":null},{"culture":null,"contentKey":"1edef406-9430-fd48-bb12-9cbb8374b748","segment":null},{"culture":null,"contentKey":"b5f9ff83-609b-9d4d-b11f-aad95677ed63","segment":null},{"culture":null,"contentKey":"211ce5cf-6d8b-f64b-bee2-247ed173cdb9","segment":null},{"culture":null,"contentKey":"0d216792-279d-7542-b62a-0129a4b8a3b6","segment":null},{"culture":null,"contentKey":"349e3340-a13c-d144-92b7-c28cc9b5fe4b","segment":null},{"culture":null,"contentKey":"6a00e444-e673-194f-a058-91c16f0f5e5e","segment":null},{"culture":null,"contentKey":"9b37027c-074c-9448-be23-621ab03c756e","segment":null},{"culture":null,"contentKey":"bd81965d-88f1-5548-b548-cb93edfa14fa","segment":null},{"culture":null,"contentKey":"33f4f4a0-5b16-9f44-bf7d-ced7c8303bba","segment":null},{"culture":null,"contentKey":"97f1321d-8a29-d346-b02c-d04c1d5f184d","segment":null},{"culture":null,"contentKey":"52e8a12c-55ac-0f4b-96bc-fa9151e105b9","segment":null},{"culture":null,"contentKey":