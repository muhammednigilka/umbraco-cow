    <metaDescription>
      <Value><![CDATA[The rules and responsibilities for using Cow Paradise games, websites, and online services.]]></Value>
    </metaDescription>
    <blocks>
      <Value><![CDATA[{"contentData":[{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"cb67a9d3-d154-6241-a785-70e9e4398a16","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Terms of Service","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h1\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"c80fb953-8276-6845-86c0-7f8ae5d19730","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eBy accessing or using Cow Paradise games and online services, you agree to these Terms of Service. If you do not agree, please stop using our services.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"d1d73ce2-7b0b-644e-af51-9b994b967bc7","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Your account","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"d37e2929-826c-9846-91d2-336cedcbe711","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eYou are responsible for maintaining the confidentiality of your account credentials. Notify us immediately of any unauthorized use of your account.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"0f604d62-bfbb-1d47-8213-1250645ff00b","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Acceptable use","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"de6fd5f3-1b65-8645-907b-8b494ce50471","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eWhen using Cow Paradise services you agree to: \u003cul\u003e\u003cli\u003e\u003cstrong\u003eNo cheating or exploiting bugs\u003c/strong\u003e\u003c/li\u003e\u003cli\u003e\u003cstrong\u003eNo reverse engineering\u003c/strong\u003e of our software\u003c/li\u003e\u003cli\u003e\u003cstrong\u003eNo resale of game assets or services\u003c/strong\u003e\u003c/li\u003e\u003cli\u003e\u003cstrong\u003eNo harmful or abusive activities\u003c/strong\u003e toward other players\u003c/li\u003e\u003cli\u003e\u003cstrong\u003eNo unauthorized distribution\u003c/strong\u003e of our content\u003c/li\u003e\u003cli\u003e\u003cstrong\u003eNo unfair gameplay manipulation\u003c/strong\u003e\u003c/li\u003e\u003cli\u003e\u003cstrong\u003eNo creation of derivative works\u003c/strong\u003e without permission\u003c/li\u003e\u003c/ul\u003e\u003c/p\u003e","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"f9a7f427-6dc5-ff42-aa37-14e385a6a6db","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"In-game purchases","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"575a913c-4b85-034e-b81d-3617bd81967b","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eAll purchases are processed by our payment providers. Virtual goods, currency, and items have no real-world cash value and are non-refundable except where required by law.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"e2f35f31-0c0f-1847-a50d-33a580d36f0b","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Intellectual property","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"9db48248-1396-f242-9a01-2fdae4304253","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eAll characters, artwork, software, and content of Cow Paradise are the property of Cow Paradise Games and its licensors. You may not copy, modify, or distribute them without written permission.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"d28419f2-2645-4c4c-ba4a-c5bdb65c5d01","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Termination","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"60b3371a-0c1a-bb41-9a3d-e4d66f0630be","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eWe may suspend or terminate accounts that violate these Terms. You may close your account at any time by contacting support@cowparadisegames.com.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"ed0d77df-e512-af47-944e-a2a08938ad11","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Disclaimers and limitation of liability","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"ecc0aca8-2405-8b4d-9d42-d2ce24e5f378","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eOur services are provided \"as is\" without warranty. To the maximum extent permitted by law, Cow Paradise Games is not liable for indirect or consequential damages arising from use of our services.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"7a87a55a-178f-a343-b379-0f3ee5adfec2","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Governing law","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"e334558a-df73-2e43-8f51-ea883f389e11","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eThese Terms are governed by the laws of the jurisdiction in which Cow Paradise Games operates. Disputes will be resolved in the competent courts of that jurisdiction. Last updated: 2026-05-28.\u003c/p\u003e","segment":null}]}],"settingsData":[],"layout":{"Umbraco.BlockList":[{"contentKey":"cb67a9d3-d154-6241-a785-70e9e4398a16"},{"contentKey":"c80fb953-8276-6845-86c0-7f8ae5d19730"},{"contentKey":"d1d73ce2-7b0b-644e-af51-9b994b967bc7"},{"contentKey":"d37e2929-826c-9846-91d2-336cedcbe711"},{"contentKey":"0f604d62-bfbb-1d47-8213-1250645ff00b"},{"contentKey":"de6fd5f3-1b65-8645-907b-8b494ce50471"},{"contentKey":"f9a7f427-6dc5-ff42-aa37-14e385a6a6db"},{"contentKey":"575a913c-4b85-034e-b81d-3617bd81967b"},{"contentKey":"e2f35f31-0c0f-1847-a50d-33a580d36f0b"},{"contentKey":"9db48248-1396-f242-9a01-2fdae4304253"},{"contentKey":"d28419f2-2645-4c4c-ba4a-c5bdb65c5d01"},{"contentKey":"60b3371a-0c1a-bb41-9a3d-e4d66f0630be"},{"contentKey":"ed0d77df-e512-af47-944e-a2a08938ad11"},{"contentKey":"ecc0aca8-2405-8b4d-9d42-d2ce24e5f378"},{"contentKey":"7a87a55a-178f-a343-b379-0f3ee5adfec2"},{"contentKey":"e334558a-df73-2e43-8f51-ea883f389e11"}]},"expose":[{"culture":null,"contentKey":"cb67a9d3-d154-6241-a785-70e9e4398a16","segment":null},{"culture":null,"contentKey":"c80fb953-8276-6845-86c0-7f8ae5d19730","segment":null},{"culture":null,"contentKey":"d1d73ce2-7b0b-644e-af51-9b994b967bc7","segment":null},{"culture":null,"contentKey":"d37e2929-826c-9846-91d2-336cedcbe711","segment":null},{"culture":null,"contentKey":"0f604d62-bfbb-1