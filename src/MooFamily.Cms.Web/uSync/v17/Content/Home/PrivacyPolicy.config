  <Properties>
    <title>
      <Value><![CDATA[Privacy Policy]]></Value>
    </title>
    <metaDescription>
      <Value><![CDATA[How Cow Paradise collects, uses, and protects your personal information across our games and websites.]]></Value>
    </metaDescription>
    <blocks>
      <Value><![CDATA[{"contentData":[{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"9852d7e0-509b-6249-9ee6-79509d72e88f","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Privacy Policy","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h1\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"4dfff48b-076b-2340-bea7-5834f2a6b3eb","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eThis Privacy Policy explains how Cow Paradise collects, uses, and protects your personal information when you visit our website or play our games. By using our services you agree to the practices described below.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"cb65c507-fdd6-3d45-9d35-c4d8115c3a1b","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Information we collect","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"f6e01097-c016-0447-9299-0c75a86d502e","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eWe collect \u003cstrong\u003eAccount information\u003c/strong\u003e (email address, display name, username), \u003cstrong\u003eGameplay data\u003c/strong\u003e (game progress, achievements, in-game purchases), \u003cstrong\u003eAnalytics information\u003c/strong\u003e (page views, clicks, session duration), \u003cstrong\u003eDevice identifiers\u003c/strong\u003e and \u003cstrong\u003eIP address\u003c/strong\u003e, and \u003cstrong\u003eCrash reports\u003c/strong\u003e to improve stability.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"150d29d1-62f5-d644-9c96-ee2d0671c59e","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"How we use your information","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"84f812d3-b767-324d-ab46-8a43f4cb7f1d","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eWe use your information to \u003cstrong\u003esave game progress and user preferences\u003c/strong\u003e, \u003cstrong\u003eimprove gameplay experience\u003c/strong\u003e, \u003cstrong\u003edisplay advertisements and analytics\u003c/strong\u003e, \u003cstrong\u003eprovide customer support\u003c/strong\u003e, \u003cstrong\u003eprevent fraud and abuse\u003c/strong\u003e, and \u003cstrong\u003ecomply with legal obligations\u003c/strong\u003e.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"35d7ec43-f087-ff43-a716-492d5ab07fb0","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Who we share data with","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"3f72ac79-2eb3-5a40-b414-5d3660f6143d","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eWe share necessary data with \u003cstrong\u003eService providers and hosting partners\u003c/strong\u003e, \u003cstrong\u003eAnalytics providers\u003c/strong\u003e, \u003cstrong\u003eAdvertising and analytics partners\u003c/strong\u003e, \u003cstrong\u003ePayment processors\u003c/strong\u003e and \u003cstrong\u003ePayment providers\u003c/strong\u003e, and \u003cstrong\u003eLegal authorities when required\u003c/strong\u003e. We do not sell your personal data to third parties.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"c9d45915-86fb-634f-85da-6a4cc0e3cca7","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Your rights","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"b89fcfb0-e48c-f846-80b6-c0e9492fdb2d","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eYou have the \u003cstrong\u003eright to access your data\u003c/strong\u003e, the \u003cstrong\u003eright to correction\u003c/strong\u003e, the \u003cstrong\u003eright to deletion\u003c/strong\u003e, the \u003cstrong\u003eright to object to processing\u003c/strong\u003e, and the \u003cstrong\u003eright to withdraw consent\u003c/strong\u003e. Contact us at privacy@cowparadisegames.com to exercise any of these rights.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"73c90431-2172-7845-9dd7-002d013559a9","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Cookies and tracking","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"084e99b9-26a4-cf46-93e6-5c87e24707a2","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eWe use cookies and similar technologies to remember your preferences and analyze how our services are used. You can adjust your cookie preferences in your browser settings.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"1b612666-694c-924a-957c-573dbff3379b","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Children\u0027s privacy","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"2943267b-ba70-9249-aa4e-9e44399fc6bf","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eCow Paradise games are designed for family audiences. We do not knowingly collect personal data from children under 13 without verifiable parental consent. Parents and guardians can contact us at any time to review or delete their child\u0027s information.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"76e9cc56-c873-1f43-93f0-0f35a0944383","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Updates to this policy","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"e9979bad-75eb-5840-8ba7-2729158cebc9","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eWe may update this Privacy Policy from time to time. Significant changes will be communicated through our website or in-game notices. Last updated: 2026-05-28.\u003c/p\u003e","segment":null}]}],"settingsData":[],"layout":{"Umbraco.BlockList":[{"contentKey":"9852d7e0-509b-6249-9ee6-79509d72e88f"},{"contentKey":"4dfff48b-076b-2340-bea7-5834f2a6b3eb"},{"contentKey":"cb65c507-fdd6-3d45-9d35-c4d8115c3a1b"},{"contentKey":"f6e01097-c016-0447-9299-0c75a86d502e"},{"contentKey":"150d29d1-62f5-d644-9c96-ee2d0671c59e"},{"contentKey":"84f812d3-b767-324d-ab46-8a43f4cb7f1d"},{"contentKey":"35d7ec43-f087-ff43-a716-492d5ab07fb0"},{"contentKey":"3f72ac79-2eb3-5a40-b414-5d3660f6143d"},{"contentKey":"c9d45915-86fb-634f-85da-6a4cc0e3cca7"},{"contentKey":"b89fcfb0-e48c-f846-80b6-c0e9492fdb2d"},{"contentKey":"73c90431-2172-7845-9dd7-002d013559a9"},{"contentKey":"084e99b9-26a4-cf46-93e6-5c87e24707a2"},{"contentKey":"1b612666-694c-924a-957c-573dbff3379b"},{"contentKey":"2943267b-ba70-9249-aa4e-9e44399fc6bf"},{"contentKey":"76e9cc56-c873-1f43-93f0-0f35a0944383"},{"contentKey":"e9979bad-75eb-5840-8ba7-2729158cebc9"}]},"expose":[{"culture":null,"contentKey":"9852d7e0-509b-6249-9ee6-79509d72e88f","segment":null},{"culture":null,"contentKey":"4dfff48b-076b-2340-bea7-5834f2a6b3eb","segment":null},{"culture":null,"contentKey":"cb65c507-fdd6-3d45-9d35-c4d8115c3a1b","segment":null},{"culture":null,"contentKey":"f6e01097-c016-0447-9299-0c75a86d502e","segment":null},{"culture":null,"contentKey":"150d29d1-62f5-d644-9c96-ee2d0671c59e","segment":null},{"culture":null,"contentKey":"84f812d3-b767-324d-ab46-8a43f4cb7f1d","segment":null},{"culture":null,"contentKey":"35d7ec43-f087-ff43-a716-492d5ab07fb0","segment":null},{"culture":null,"contentKey":"3f72ac79-2eb3-5a40-b414-5d3660f6143d","segment":null},{"culture":null,"contentKey":"c9d45915-86fb-634f-85da-6a4cc0e3cca7","segment":null},{"culture":null,"contentKey":"b89fcfb0-e48c-f846-80b6-c0e9492fdb2d","segment":null},{"culture":null,"contentKey":"73c90431-2172-7845-9dd7-002d013559a9","segment":null},{"culture":null,"contentKey":"084e99b9-26a4-cf46-93e6-5c87e24707a2","segment":null},{"culture":null,"contentKey":"1b612666-694c-924a-957c-573dbff3379b","segment":null},{"culture":null,"contentKey":"2943267b-ba70-9249-aa4e-9e44399fc6bf","segment":null},{"culture":null,"contentKey":"76e9cc56-c873-1f43-93f0-0f35a0944383","segment":null},{"culture":null,"contentKey":"e9979bad-75eb-5840-8ba7-2729158cebc9","segment":null}]}]]></Value>
    </blocks>
