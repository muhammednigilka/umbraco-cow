  <Properties>
    <title>
      <Value><![CDATA[About Us]]></Value>
    </title>
    <metaDescription>
      <Value><![CDATA[The Story Behind Cow Paradise — from a simple sketch to a cosmic phenomenon.]]></Value>
    </metaDescription>
    <blocks>
      <Value><![CDATA[{"contentData":[{"contentTypeKey":"e1a00001-0000-0000-0000-000000000001","key":"e99b8baa-7d9b-7d4c-a81c-bd5c6f3e8ac1","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"bannerTitle","value":"Our Story","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"bannerSubtitle","value":"About Cow Paradise","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"bannerBody","value":"From a simple sketch to a cosmic phenomenon -- the journey of Cow Paradise has been guided by one belief: that play and learning belong together.","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"ctaPrimaryLabel","value":"Meet the Team","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"ctaPrimaryUrl","value":"#team","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"ctaSecondaryLabel","value":"","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"ctaSecondaryUrl","value":"","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"23336b31-7590-5c44-82bf-6b80883bc62e","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"From a Simple Sketch to a Cosmic Phenomenon","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"213efd23-3817-644b-8a70-a761585ad60f","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eCow Paradise began with a few hand-drawn cows in a sketchbook and grew into a universe of games, stories, and characters loved by families around the world. We design every experience with kids in mind -- gentle humor, smart learning, and adventures that stick.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"635833c7-2baf-0048-b0c6-b966b91d6842","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"What We Stand For","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"e1a00003-0000-0000-0000-000000000003","key":"7401fd9b-afea-0f44-b891-91ce37a592c7","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureNumber","value":"01","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureTitle","value":"Make Learning Fun","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"featureDescription","value":"We design every game and story around playful discovery, so kids learn without realizing they\u0027re learning.","segment":null}]},{"contentTypeKey":"e1a00003-0000-0000-0000-000000000003","key":"76e80747-0b99-534b-b23c-f47c3a261576","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureNumber","value":"02","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureTitle","value":"Empower Creativity","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"featureDescription","value":"Our characters and worlds invite kids to imagine, build, and tell their own stories.","segment":null}]},{"contentTypeKey":"e1a00003-0000-0000-0000-000000000003","key":"5d8cb344-60a1-f449-817e-16427d3346be","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureNumber","value":"03","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureTitle","value":"Foster Growth","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"featureDescription","value":"Each story models curiosity, kindness, and resilience -- so kids grow alongside the Moo Family.","segment":null}]},{"contentTypeKey":"e1a00003-0000-0000-0000-000000000003","key":"1b2144eb-bdd7-5143-bcae-a0c8a0ec1485","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureNumber","value":"04","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"featureTitle","value":"Build Community","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"featureDescription","value":"We\u0027re building a friendly, family-first community of parents, kids, and creators around the Cowverse.","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"d3f0de95-d3cb-0842-a9d5-78266f8229b7","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Our Mission","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"ddfcce23-67df-1f4d-b62b-f1be5f56d2fa","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eTo merge play, learning, and storytelling into one universe -- where every child feels invited to imagine, explore, and grow.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"1c746db6-003f-e24d-b815-47685f6acf43","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Our Vision","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"f7005ccc-f015-6f46-8b1d-949d4643c4ce","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eA world where children grow up surrounded by characters who teach kindness, curiosity, and the joy of trying something new.\u003c/p\u003e","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"683ae679-caeb-8048-b714-0860cc711c80","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"From Napkin Doodles to Game Hero","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"e1a00004-0000-0000-0000-000000000004","key":"b09fc1a6-d4ed-3842-9c06-9fbf9bc4d9f6","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"timelineYear","value":"2022","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"timelineTitle","value":"The Spark","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"timelineDescription","value":"Cow Paradise begins as a sketchbook of friendly cow characters and a single question: what if learning felt like an adventure?","segment":null}]},{"contentTypeKey":"e1a00004-0000-0000-0000-000000000004","key":"81195cd8-21d9-6a47-ad72-cb6f47380944","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"timelineYear","value":"2023","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"timelineTitle","value":"Meet Atlas","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"timelineDescription","value":"The Moo Family universe gains its first six characters and a shared storyline that ties games and stories together.","segment":null}]},{"contentTypeKey":"e1a00004-0000-0000-0000-000000000004","key":"4dc004c8-d5fc-4344-b8eb-9fe920644b02","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"timelineYear","value":"2024","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"timelineTitle","value":"Hero Highlights","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"timelineDescription","value":"Cow Run launches on Google Play and crosses 200,000 downloads. Mooski enters early access; new stories ship weekly.","segment":null}]},{"contentTypeKey":"e1a00004-0000-0000-0000-000000000004","key":"88cf263e-9746-d94b-a0f3-1caca3c07196","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"timelineYear","value":"2026","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"timelineTitle","value":"The Big Showdown","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"timelineDescription","value":"Paintball Madness lands on Steam, multiplayer arrives, and the Cowverse opens its doors to a growing community of families worldwide.","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"152386d2-6e9f-444f-b731-4b92819c5ac3","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"Meet the Team","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"96460a35-983c-8b4b-82a8-2b497c1148e2","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"\u003cp\u003eThe Moo Family universe is the work of artists, engineers, and storytellers from across the world. Visit the team page to meet the people behind the cows.\u003c/p\u003e","segment":null}]}],"settingsData":[],"layout":{"Umbraco.BlockList":[{"contentKey":"e99b8baa-7d9b-7d4c-a81c-bd5c6f3e8ac1"},{"contentKey":"23336b31-7590-5c44-82bf-6b80883bc62e"},{"contentKey":"213efd23-3817-644b-8a70-a761585ad60f"},{"contentKey":"635833c7-2baf-0048-b0c6-b966b91d6842"},{"contentKey":"7401fd9b-afea-0f44-b891-91ce37a592c7"},{"contentKey":"76e80747-0b99-534b-b23c-f47c3a261576"},{"contentKey":"5d8cb344-60a1-f449-817e-16427d3346be"},{"contentKey":"1b2144eb-bdd7-5143-bcae-a0c8a0ec1485"},{"contentKey":"d3f0de95-d3cb-0842-a9d5-78266f8229b7"},{"contentKey":"ddfcce23-67df-1f4d-b62b-f1be5f56d2fa"},{"contentKey":"1c746db6-003f-e24d-b815-47685f6acf43"},{"contentKey":"f7005ccc-f015-6f46-8b1d-949d4643c4ce"},{"contentKey":"683ae679-caeb-8048-b714-0860cc711c80"},{"contentKey":"b09fc1a6-d4ed-3842-9c06-9fbf9bc4d9f6"},{"contentKey":"81195cd8-21d9-6a47-ad72-cb6f47380944"},{"contentKey":"4dc004c8-d5fc-4344-b8eb-9fe920644b02"},{"contentKey":"88cf263e-9746-d94b-a0f3-1caca3c07196"},{"contentKey":"152386d2-6e9f-444f-b731-4b92819c5ac3"},{"contentKey":"96460a35-983c-8b4b-82a8-2b497c1148e2"}]},"expose":[{"culture":null,"contentKey":"e99b8baa-7d9b-7d4c-a81c-bd5c6f3e8ac1","segment":null},{"culture":null,"contentKey":"23336b31-7590-5c44-82bf-6b80883bc62e","segment":null},{"culture":null,"contentKey":"213efd23-3817-644b-8a70-a761585ad60f","segment":null},{"culture":null,"contentKey":"635833c7-2baf-0048-b0c6-b966b91d6842","segment":null},{"culture":null,"contentKey":"7401fd9b-afea-0f44-b891-91ce37a592c7","segment":null},{"culture":null,"contentKey":"76e80747-0b99-534b-b23c-f47c3a261576","segment":null},{"culture":null,"contentKey":"5d8cb344-60a1-f449-817e-16427d3346be","segment":null},{"culture":null,"contentKey":"1b2144eb-bdd7-5143-bcae-a0c8a0ec1485","segment":null},{"culture":null,"contentKey":"d3f0de95-d3cb-0842-a9d5-78266f8229b7","segment":null},{"culture":null,"contentKey":"ddfcce23-67df-1f4d-b62b-f1be5f56d2fa","segment":null},{"culture":null,"contentKey":"1c746db6-003f-e24d-b815-47685f6acf43","segment":null},{"culture":null,"contentKey":"f7005ccc-f015-6f46-8b1d-949d4643c4ce","segment":null},{"culture":null,"contentKey":"683ae679-caeb-8048-b714-0860cc711c80","segment":null},{"culture":null,"contentKey":"b09fc1a6-d4ed-3842-9c06-9fbf9bc4d9f6","segment":null},{"culture":null,"contentKey":"81195cd8-21d9-6a47-ad72-cb6f47380944","segment":null},{"culture":null,"contentKey":"4dc004c8-d5fc-4344-b8eb-9fe920644b02","segment":null},{"culture":null,"contentKey":"88cf263e-9746-d94b-a0f3-1caca3c07196","segment":null},{"culture":null,"contentKey":"152386d2-6e9f-444f-b731-4b92819c5ac3","segment":null},{"culture":null,"contentKey":"96460a35-983c-8b4b-82a8-2b497c1148e2","segment":null}]}]]></Value>
