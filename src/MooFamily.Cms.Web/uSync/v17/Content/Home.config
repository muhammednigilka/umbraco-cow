    <blocks>
      <Value><![CDATA[{"contentData":[{"contentTypeKey":"e1a00001-0000-0000-0000-000000000001","key":"7705a7cd-fce3-9d47-8427-22d796f016f0","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"bannerTitle","value":"Where Games Become a Universe","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"bannerSubtitle","value":"Become a Cow Paradise","segment":null},{"culture":null,"editorAlias":"Umbraco.TextArea","alias":"bannerBody","value":"We're building a playful universe filled with stories, adventures, and unforgettable characters. Play, learn, and grow with the Moo Family.","segment":null},{"culture":null,"editorAlias":"Umbraco.MediaPicker3","alias":"bannerBackgroundImage","value":"","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"ctaPrimaryLabel","value":"Explore Games","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"ctaPrimaryUrl","value":"/games","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"ctaSecondaryLabel","value":"Meet the Moo Family","segment":null},{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"ctaSecondaryUrl","value":"/moo-family","segment":null}]},{"contentTypeKey":"db096faa-0e2d-4c32-882a-1cf10ae8bb94","key":"aa000002-0000-0000-0000-000000000002","values":[{"culture":null,"editorAlias":"Umbraco.TextBox","alias":"headingText","value":"What is Cow Paradise?","segment":null},{"culture":null,"editorAlias":"Umbraco.DropDown.Flexible","alias":"headingLevel","value":"[\"h2\"]","segment":null}]},{"contentTypeKey":"6b3cf24d-4934-4093-b793-31c417a271fa","key":"aa000003-0000-0000-0000-000000000003","values":[{"culture":null,"editorAlias":"Umbraco.RichText","alias":"content","value":"<p>At Cow Paradise, we're creating more than just games -- we're building a playful universe filled with stories, adventures, and unforgettable characters.</p>","segment":null}]},{"contentTypeKey":"e1a00002-0000-0000-0000-000000000002","key":"aa000004-0000-0000-00